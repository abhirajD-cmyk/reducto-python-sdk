REDUCTO_API_KEY=
REDUCTO_ENVIRONMENT=production

ORACLE_USER=REDUCTO_RAG_APP
ORACLE_PASSWORD=
ORACLE_DSN=localhost:1521/FREEPDB1
ORACLE_VECTOR_DIMENSIONS=2048

# Embeddings: use "oracle" for DBDev LLMs, "cohere" for Cohere, or "auto".
EMBEDDING_PROVIDER=oracle

ORACLE_LLM_API_KEY=
ORACLE_LLM_BASE_URL=https://dbdevllms.oraclecorp.com
ORACLE_LLM_EMBED_MODEL=nim/llama-3.2-nv-embedqa-1b-v2
ORACLE_LLM_EMBED_BATCH_SIZE=1
ORACLE_LLM_EMBED_TIMEOUT_SECONDS=30
ORACLE_LLM_EMBED_MAX_RETRIES=4
ORACLE_LLM_EMBED_MAX_CHARS=16000

CO_API_KEY=
COHERE_EMBED_MODEL=embed-english-light-v3.0
COHERE_EMBED_BATCH_SIZE=32
COHERE_EMBED_TIMEOUT_SECONDS=30
COHERE_EMBED_MAX_RETRIES=4

SEC_USER_AGENT="reducto-oracledb your-email@example.com"

# Live end-to-end test switch. Disabled by default because it calls
# Oracle, Reducto, and the configured embedding provider.
RUN_E2E_INTEGRATION=0
